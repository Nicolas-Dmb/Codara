{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "panel": "dedicated", "group": "run-all" },
      "isBackground": true
    },
    {
      "label": "api",
      "type": "shell",
      "command": "uv run uvicorn src.api.main:app",
      "options": { "cwd": "${workspaceFolder}/api" },
      "presentation": { "panel": "dedicated", "group": "run-all" },
      "isBackground": true
    },
    {
      "label": "engine",
      "type": "shell",
      "command": "cargo run",
      "options": { "cwd": "${workspaceFolder}/engine" },
      "presentation": { "panel": "dedicated", "group": "run-all" },
      "isBackground": true
    },
    {
      "label": "run-all",
      "dependsOn": ["frontend", "api", "engine"],
      "dependsOrder": "parallel"
    }
  ]
}